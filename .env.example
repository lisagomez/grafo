# ===========================================
# Environment Configuration
# Generated by SaaS Factory
# ===========================================

# Application
NODE_ENV=development
APP_NAME="grafo"
APP_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Backend
PORT=8000
API_PREFIX=/api

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/saas_db

# Neo4j (grafo legal) — al levantar Docker, solo poner credenciales y arrancar.
# bolt:// para conexion directa; usa neo4j+s:// para Aura (cloud).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=please-change-me
NEO4J_DATABASE=neo4j

# Legal Context Resolver
DEFAULT_COUNTRY=MX

# Knowledge Base (bóveda de conocimiento: Fuente de Verdad de reglas fiscales).
# Ruta RELATIVA a la raíz del proyecto, para que funcione igual en local y en el
# servidor del cliente. El backend la resuelve a absoluta (config.knowledgeBase.root).
KNOWLEDGE_BASE_PATH=./knowledge-base

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# Email Verification
EMAIL_VERIFICATION_REQUIRED=false

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session
SESSION_SECRET=your-session-secret-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_BASIC=price_basic_monthly
STRIPE_PRICE_ID_PRO=price_pro_monthly
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_monthly

# Permissions
DEFAULT_ROLE=member
SUPER_ADMIN_EMAIL=admin@example.com

# ===========================================
# Add your custom environment variables below
# ===========================================
